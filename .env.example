# ── BASE DE DATOS ──────────────────
# Cadena de conexión principal a la instancia de PostgreSQL. Obligatoria.
PG_URL=postgres://usuario:contraseña@localhost:5432/nombre_db

# ── SEGURIDAD ──────────────────
# Llave secreta utilizada para la firma y validación de tokens JWT de sesión. Obligatoria.
JWT_SECRET=cambiar_por_una_llave_segura_2026

# Llave de seguridad para restringir el acceso a procesos de inicialización del sistema. Obligatoria.
SETUP_SECRET=setup_key_2026

# ── CORREO (OPCIONAL) ──────────────────
# Cuenta de correo Gmail institucional utilizada para el envío de alertas de vencimiento. Opcional.
GMAIL_USER=alertas.sda@gmail.com

# Contraseña de aplicación generada desde la configuración de seguridad de la cuenta Google. Opcional.
GMAIL_APP_PASSWORD=abcd-efgh-ijkl-mnop

# ── SERVIDOR ──────────────────
# Puerto de escucha para el servidor de aplicaciones Express. Opcional (valor por defecto: 3000).
PORT=3000

# URL base del servidor para la construcción de hipervínculos en las notificaciones. Opcional.
BASE_URL=http://localhost:3000

# ── TAREAS AUTOMÁTICAS ──────────────────
# Token de seguridad para la ejecución remota de tareas programadas (Cron). Opcional.
CRON_SECRET=token_cron_2026

# ── MISC ──────────────────
# Ruta absoluta al binario pg_dump para la ejecución de respaldos de base de datos. Requerida para backups.
PG_DUMP_PATH=C:\Ruta\Hacia\pg_dump.exe

# ── SEGURIDAD ADICIONAL ──────────────────
# Contraseña segura para el usuario admin. Requerida antes de correr: npm run seed
ADMIN_PASSWORD=

# Configuración de SSL para la conexión a la base de datos. true/false.
DB_SSL=false
