{
  "name": "sda-imss-sinaloa",
  "version": "1.0.0",
  "description": "SDA Sistema de Administración IMSS OOAD Sinaloa",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "electron": "electron .",
    "build:win": "electron-builder --win",
    "seed": "node server/db/seed.js",
    "init-db": "node server/db/init.js",
    "migrate-cvmsg": "node server/scripts/migrate-cvmsg.js",
    "seed:pc": "node server/db/seed-pc.js",
    "seed:extintores": "node server/db/seed-extintores.js",
    "service:install": "node server/scripts/service-install.js",
    "service:uninstall": "node server/scripts/service-uninstall.js"
  },
  "build": {
    "appId": "mx.gob.imss.sda",
    "productName": "SDA Sistema de Administración",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "SDA.png",
      "server/**/*",
      "public/**/*",
      "node_modules/**/*",
      ".env",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^4.21.1",
    "express-rate-limit": "^8.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "node-windows": "^1.0.0-beta.8",
    "nodemailer": "^6.10.1",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  }
}
